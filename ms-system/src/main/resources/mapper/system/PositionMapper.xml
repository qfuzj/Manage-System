<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ms.system.mapper.PositionMapper">
    
    <resultMap type="Position" id="PositionResult">
        <result property="id"    column="id"    />
        <result property="positionName"    column="position_name"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectPositionVo">
        select id, position_name, remark from base_position
    </sql>

    <select id="selectPositionList" parameterType="Position" resultMap="PositionResult">
        <include refid="selectPositionVo"/>
        <where>  
            <if test="positionName != null  and positionName != ''"> and position_name like concat('%', #{positionName}, '%')</if>
        </where>
    </select>
    
    <select id="selectPositionById" parameterType="Long" resultMap="PositionResult">
        <include refid="selectPositionVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertPosition" parameterType="Position" useGeneratedKeys="true" keyProperty="id">
        insert into base_position
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="positionName != null and positionName != ''">position_name,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="positionName != null and positionName != ''">#{positionName},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updatePosition" parameterType="Position">
        update base_position
        <trim prefix="SET" suffixOverrides=",">
            <if test="positionName != null and positionName != ''">position_name = #{positionName},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deletePositionById" parameterType="Long">
        delete from base_position where id = #{id}
    </delete>

    <delete id="deletePositionByIds" parameterType="String">
        delete from base_position where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>