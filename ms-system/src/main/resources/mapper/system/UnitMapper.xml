<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ms.system.mapper.UnitMapper">
    
    <resultMap type="Unit" id="UnitResult">
        <result property="id"    column="id"    />
        <result property="code"    column="code"    />
        <result property="name"    column="name"    />
        <result property="description"    column="description"    />
        <result property="isMainUnit"    column="is_main_unit"    />
        <result property="mainUnitId"    column="main_unit_id"    />
        <result property="conversionRatio"    column="conversion_ratio"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="deleteFlag"    column="delete_flag"    />
    </resultMap>

    <sql id="selectUnitVo">
        select id, code, name, description, is_main_unit, main_unit_id, conversion_ratio, status, create_time, update_time, delete_flag from unit
    </sql>

    <select id="selectUnitList" parameterType="Unit" resultMap="UnitResult">
        <include refid="selectUnitVo"/>
        <where>  
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectUnitById" parameterType="Long" resultMap="UnitResult">
        <include refid="selectUnitVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertUnit" parameterType="Unit">
        insert into unit
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="description != null">description,</if>
            <if test="isMainUnit != null">is_main_unit,</if>
            <if test="mainUnitId != null">main_unit_id,</if>
            <if test="conversionRatio != null">conversion_ratio,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleteFlag != null">delete_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="description != null">#{description},</if>
            <if test="isMainUnit != null">#{isMainUnit},</if>
            <if test="mainUnitId != null">#{mainUnitId},</if>
            <if test="conversionRatio != null">#{conversionRatio},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="deleteFlag != null">#{deleteFlag},</if>
         </trim>
    </insert>

    <update id="updateUnit" parameterType="Unit">
        update unit
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="isMainUnit != null">is_main_unit = #{isMainUnit},</if>
            <if test="mainUnitId != null">main_unit_id = #{mainUnitId},</if>
            <if test="conversionRatio != null">conversion_ratio = #{conversionRatio},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="deleteFlag != null">delete_flag = #{deleteFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUnitById" parameterType="Long">
        delete from unit where id = #{id}
    </delete>

    <delete id="deleteUnitByIds" parameterType="String">
        delete from unit where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>