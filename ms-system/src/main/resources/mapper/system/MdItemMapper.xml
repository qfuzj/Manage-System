<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ms.system.mapper.MdItemMapper">

    <resultMap type="MdItem" id="MdItemResult">
        <result property="itemId" column="item_id" />
        <result property="itemCode" column="item_code" />
        <result property="itemName" column="item_name" />
        <result property="specification" column="specification" />
        <result property="unitOfMeasure" column="unit_of_measure" />
        <result property="unitName" column="unit_name" />
        <result property="itemOrProduct" column="item_or_product" />
        <result property="itemTypeId" column="item_type_id" />
        <result property="itemTypeCode" column="item_type_code" />
        <result property="itemTypeName" column="item_type_name" />
        <result property="enableFlag" column="enable_flag" />
        <result property="safeStockFlag" column="safe_stock_flag" />
        <result property="minStock" column="min_stock" />
        <result property="maxStock" column="max_stock" />
        <result property="highValue" column="high_value" />
        <result property="batchFlag" column="batch_flag" />
        <result property="remark" column="remark" />
        <result property="attr1" column="attr1" />
        <result property="attr2" column="attr2" />
        <result property="attr3" column="attr3" />
        <result property="attr4" column="attr4" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <!-- 新增：SOP 子表嵌套查询映射 -->
    <resultMap id="MdItemWithSubTablesResult" type="MdItem" extends="MdItemResult">
        <collection property="productSopList" column="item_id" select="selectProductSopByItemId" />
        <collection property="mdItemBomList" column="item_id" select="selectMdItemBomByItemId" />
        <collection property="mdItemSipList" column="item_id" select="selectMdItemSipByItemId" />
    </resultMap>

    <!-- 新增：SOP 子表 resultMap -->
    <resultMap type="ProductSop" id="ProductSopResult">
        <result property="sopId" column="sop_id" />
        <result property="itemId" column="item_id" />
        <result property="orderNum" column="order_num" />
        <result property="processId" column="process_id" />
        <result property="processCode" column="process_code" />
        <result property="processName" column="process_name" />
        <result property="sopTitle" column="sop_title" />
        <result property="sopDescription" column="sop_description" />
        <result property="sopUrl" column="sop_url" />
        <result property="remark" column="remark" />
        <result property="attr1" column="attr1" />
        <result property="attr2" column="attr2" />
        <result property="attr3" column="attr3" />
        <result property="attr4" column="attr4" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <!-- 新增：BOM 子表 resultMap -->
    <resultMap type="MdProductBom" id="MdItemBomResult">
        <result property="bomId" column="bom_id" />
        <result property="itemId" column="item_id" />
        <result property="bomItemId" column="bom_item_id" />
        <result property="bomItemCode" column="bom_item_code" />
        <result property="bomItemName" column="bom_item_name" />
        <result property="bomItemSpec" column="bom_item_spec" />
        <result property="unitOfMeasure" column="unit_of_measure" />
        <result property="itemOrProduct" column="item_or_product" />
        <result property="quantity" column="quantity" />
        <result property="enableFlag" column="enable_flag" />
        <result property="remark" column="remark" />
        <result property="attr1" column="attr1" />
        <result property="attr2" column="attr2" />
        <result property="attr3" column="attr3" />
        <result property="attr4" column="attr4" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <!-- 新增：SIP 子表 resultMap -->
    <resultMap type="ProductSip" id="MdItemSipResult">
        <result property="sipId" column="sip_id" />
        <result property="itemId" column="item_id" />
        <result property="orderNum" column="order_num" />
        <result property="processId" column="process_id" />
        <result property="processCode" column="process_code" />
        <result property="processName" column="process_name" />
        <result property="sipTitle" column="sip_title" />
        <result property="sipDescription" column="sip_description" />
        <result property="sipUrl" column="sip_url" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectMdItemVo">
        select item_id, item_code, item_name, specification, unit_of_measure, unit_name, item_or_product,
               item_type_id, item_type_code, item_type_name, enable_flag, safe_stock_flag, min_stock, max_stock,
               high_value, batch_flag, remark, attr1, attr2, attr3, attr4, create_by, create_time, update_by, update_time
        from md_item
    </sql>

    <select id="selectMdItemList" parameterType="MdItem" resultMap="MdItemResult">
        <include refid="selectMdItemVo" />
        <where>
            <if test="itemCode != null and itemCode != ''">and item_code = #{itemCode}</if>
            <if test="itemName != null and itemName != ''">and item_name like concat('%', #{itemName}, '%')</if>
            <if test="enableFlag != null and enableFlag != ''">and enable_flag = #{enableFlag}</if>
        </where>
    </select>

    <!-- 新增：主表详情改为嵌套 select，避免多子表笛卡尔积 -->
    <select id="selectMdItemByItemId" parameterType="Long" resultMap="MdItemWithSubTablesResult">
        <include refid="selectMdItemVo" />
        where item_id = #{itemId}
    </select>

    <!-- 新增：SOP 子表独立查询 -->
    <select id="selectProductSopByItemId" parameterType="Long" resultMap="ProductSopResult">
        select sop_id, item_id, order_num, process_id, process_code, process_name, sop_title, sop_description,
               sop_url, remark, attr1, attr2, attr3, attr4, create_by, create_time, update_by, update_time
        from md_product_sop
        where item_id = #{itemId}
        order by order_num asc, sop_id asc
    </select>

    <!-- 新增：BOM 子表独立查询 -->
    <select id="selectMdItemBomByItemId" parameterType="Long" resultMap="MdItemBomResult">
        select bom_id, item_id, bom_item_id, bom_item_code, bom_item_name, bom_item_spec, unit_of_measure,
               item_or_product, quantity, enable_flag, remark, attr1, attr2, attr3, attr4,
               create_by, create_time, update_by, update_time
        from md_product_bom
        where item_id = #{itemId}
        order by bom_id asc
    </select>

    <!-- 新增：SIP 子表独立查询 -->
    <select id="selectMdItemSipByItemId" parameterType="Long" resultMap="MdItemSipResult">
        select sip_id, item_id, order_num, process_id, process_code, process_name, sip_title, sip_description,
               sip_url, remark, create_by, create_time, update_by, update_time
        from md_product_sip
        where item_id = #{itemId}
        order by order_num asc, sip_id asc
    </select>

    <insert id="insertMdItem" parameterType="MdItem" useGeneratedKeys="true" keyProperty="itemId">
        insert into md_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="itemCode != null and itemCode != ''">item_code,</if>
            <if test="itemName != null and itemName != ''">item_name,</if>
            <if test="specification != null">specification,</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''">unit_of_measure,</if>
            <if test="unitName != null">unit_name,</if>
            <if test="itemOrProduct != null and itemOrProduct != ''">item_or_product,</if>
            <if test="itemTypeId != null">item_type_id,</if>
            <if test="itemTypeCode != null">item_type_code,</if>
            <if test="itemTypeName != null">item_type_name,</if>
            <if test="enableFlag != null and enableFlag != ''">enable_flag,</if>
            <if test="safeStockFlag != null and safeStockFlag != ''">safe_stock_flag,</if>
            <if test="minStock != null">min_stock,</if>
            <if test="maxStock != null">max_stock,</if>
            <if test="highValue != null and highValue != ''">high_value,</if>
            <if test="batchFlag != null and batchFlag != ''">batch_flag,</if>
            <if test="remark != null">remark,</if>
            <if test="attr1 != null">attr1,</if>
            <if test="attr2 != null">attr2,</if>
            <if test="attr3 != null">attr3,</if>
            <if test="attr4 != null">attr4,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="itemCode != null and itemCode != ''">#{itemCode},</if>
            <if test="itemName != null and itemName != ''">#{itemName},</if>
            <if test="specification != null">#{specification},</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''">#{unitOfMeasure},</if>
            <if test="unitName != null">#{unitName},</if>
            <if test="itemOrProduct != null and itemOrProduct != ''">#{itemOrProduct},</if>
            <if test="itemTypeId != null">#{itemTypeId},</if>
            <if test="itemTypeCode != null">#{itemTypeCode},</if>
            <if test="itemTypeName != null">#{itemTypeName},</if>
            <if test="enableFlag != null and enableFlag != ''">#{enableFlag},</if>
            <if test="safeStockFlag != null and safeStockFlag != ''">#{safeStockFlag},</if>
            <if test="minStock != null">#{minStock},</if>
            <if test="maxStock != null">#{maxStock},</if>
            <if test="highValue != null and highValue != ''">#{highValue},</if>
            <if test="batchFlag != null and batchFlag != ''">#{batchFlag},</if>
            <if test="remark != null">#{remark},</if>
            <if test="attr1 != null">#{attr1},</if>
            <if test="attr2 != null">#{attr2},</if>
            <if test="attr3 != null">#{attr3},</if>
            <if test="attr4 != null">#{attr4},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateMdItem" parameterType="MdItem">
        update md_item
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemCode != null and itemCode != ''">item_code = #{itemCode},</if>
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="specification != null">specification = #{specification},</if>
            <if test="unitOfMeasure != null and unitOfMeasure != ''">unit_of_measure = #{unitOfMeasure},</if>
            <if test="unitName != null">unit_name = #{unitName},</if>
            <if test="itemOrProduct != null and itemOrProduct != ''">item_or_product = #{itemOrProduct},</if>
            <if test="itemTypeId != null">item_type_id = #{itemTypeId},</if>
            <if test="itemTypeCode != null">item_type_code = #{itemTypeCode},</if>
            <if test="itemTypeName != null">item_type_name = #{itemTypeName},</if>
            <if test="enableFlag != null and enableFlag != ''">enable_flag = #{enableFlag},</if>
            <if test="safeStockFlag != null and safeStockFlag != ''">safe_stock_flag = #{safeStockFlag},</if>
            <if test="minStock != null">min_stock = #{minStock},</if>
            <if test="maxStock != null">max_stock = #{maxStock},</if>
            <if test="highValue != null and highValue != ''">high_value = #{highValue},</if>
            <if test="batchFlag != null and batchFlag != ''">batch_flag = #{batchFlag},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="attr1 != null">attr1 = #{attr1},</if>
            <if test="attr2 != null">attr2 = #{attr2},</if>
            <if test="attr3 != null">attr3 = #{attr3},</if>
            <if test="attr4 != null">attr4 = #{attr4},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where item_id = #{itemId}
    </update>

    <delete id="deleteMdItemByItemId" parameterType="Long">
        delete from md_item where item_id = #{itemId}
    </delete>

    <delete id="deleteMdItemByItemIds" parameterType="String">
        delete from md_item where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <delete id="deleteProductSopByItemIds" parameterType="String">
        delete from md_product_sop where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <delete id="deleteProductSopByItemId" parameterType="Long">
        delete from md_product_sop where item_id = #{itemId}
    </delete>

    <!-- 新增：BOM 子表按主表批量删除 -->
    <delete id="deleteMdItemBomByItemIds" parameterType="String">
        delete from md_product_bom where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <!-- 新增：BOM 子表按主表删除 -->
    <delete id="deleteMdItemBomByItemId" parameterType="Long">
        delete from md_product_bom where item_id = #{itemId}
    </delete>

    <!-- 新增：SIP 子表按主表批量删除 -->
    <delete id="deleteMdItemSipByItemIds" parameterType="String">
        delete from md_product_sip where item_id in
        <foreach item="itemId" collection="array" open="(" separator="," close=")">
            #{itemId}
        </foreach>
    </delete>

    <!-- 新增：SIP 子表按主表删除 -->
    <delete id="deleteMdItemSipByItemId" parameterType="Long">
        delete from md_product_sip where item_id = #{itemId}
    </delete>

    <insert id="batchProductSop">
        insert into md_product_sop
        (sop_id, item_id, order_num, process_id, process_code, process_name, sop_title, sop_description, sop_url,
         remark, attr1, attr2, attr3, attr4, create_by, create_time, update_by, update_time)
        values
        <foreach item="item" collection="list" separator=",">
            (#{item.sopId}, #{item.itemId}, #{item.orderNum}, #{item.processId}, #{item.processCode}, #{item.processName},
             #{item.sopTitle}, #{item.sopDescription}, #{item.sopUrl}, #{item.remark}, #{item.attr1}, #{item.attr2},
             #{item.attr3}, #{item.attr4}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime})
        </foreach>
    </insert>

    <!-- 新增：BOM 子表批量插入 -->
    <insert id="batchMdItemBom">
        insert into md_product_bom
        (bom_id, item_id, bom_item_id, bom_item_code, bom_item_name, bom_item_spec, unit_of_measure, quantity,
         remark, create_by, create_time, update_by, update_time)
        values
        <foreach item="item" collection="list" separator=",">
            (#{item.bomId}, #{item.itemId}, #{item.bomItemId}, #{item.bomItemCode}, #{item.bomItemName},
             #{item.bomItemSpec}, #{item.unitOfMeasure}, #{item.quantity}, #{item.remark}, #{item.createBy},
             #{item.createTime}, #{item.updateBy}, #{item.updateTime})
        </foreach>
    </insert>

    <!-- 新增：SIP 子表批量插入 -->
    <insert id="batchMdItemSip">
        insert into md_product_sip
        (sip_id, item_id, order_num, process_id, process_code, process_name, sip_title, sip_description, sip_url,
         remark, create_by, create_time, update_by, update_time)
        values
        <foreach item="item" collection="list" separator=",">
            (#{item.sipId}, #{item.itemId}, #{item.orderNum}, #{item.processId}, #{item.processCode}, #{item.processName},
             #{item.sipTitle}, #{item.sipDescription}, #{item.sipUrl}, #{item.remark}, #{item.createBy},
             #{item.createTime}, #{item.updateBy}, #{item.updateTime})
        </foreach>
    </insert>
</mapper>
